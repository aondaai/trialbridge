{
  "name": "trialbridge",
  "version": "0.1.0",
  "private": true,
  "description": "TrialBridge (Elegivel) — two-sided clinical-trial site-feasibility tool. Deterministic matcher, protocol softening, counts-not-rows aggregation.",
  "comment": "Scripts call bins by explicit relative path: the project path contains a colon, which corrupts npm's PATH injection and breaks bare-name lookup.",
  "scripts": {
    "dev": "./node_modules/.bin/next dev",
    "build": "./node_modules/.bin/next build",
    "start": "./node_modules/.bin/next start",
    "typecheck": "./node_modules/.bin/tsc --noEmit",
    "test": "./node_modules/.bin/vitest run",
    "test:watch": "./node_modules/.bin/vitest",
    "generate-data": "./node_modules/.bin/tsx scripts/generate-data.ts",
    "generate-messy-csv": "./node_modules/.bin/tsx scripts/generate-messy-csv.ts",
    "db:seed": "./node_modules/.bin/tsx prisma/seed.ts",
    "db:seed-autofill": "./node_modules/.bin/tsx scripts/seed-autofill.ts",
    "mcp:cohort": "./node_modules/.bin/tsx scripts/mcp-cohort-server.ts",
    "demo": "./node_modules/.bin/tsx scripts/demo.ts",
    "demo:intake": "./node_modules/.bin/tsx scripts/demo-intake.ts",
    "build-vocab-index": "./node_modules/.bin/tsx scripts/build-vocab-index.ts",
    "build-concept-map": "./node_modules/.bin/tsx scripts/build-concept-map.ts",
    "smoke": "./node_modules/.bin/tsx scripts/smoke.ts",
    "db:push": "./node_modules/.bin/prisma db push",
    "postinstall": "./node_modules/.bin/prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@prisma/client": "^6.1.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
