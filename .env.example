# Copy this to .env.local and fill in your own values. .env.local is
# gitignored — never commit real credentials.

# --- Claude API key (parse service + narrative drafter + MCA orchestrator) ---
# One key, three consumers:
#   - src/lib/parse.ts (protocol → Criterion[]) — optional; falls back to the
#     cached, verified hero fixture without it (ADR Decision 3B).
#   - src/lib/feasibility-autofill/resolvers/narrative.ts (archetype D drafts) —
#     optional; falls back to a grounded template without it.
#   - The Managed-Agents orchestrator (ADR-002 M1+) — REQUIRED to run live.
# MCA uses this same key; the managed-agents beta header is set by the SDK.
# Residency note (ADR-002): this key powers only cloud-side A/B/D. Archetype C
# (patient counts) stays site-side over the cohort.preview MCP tool — no patient
# data ever reaches MCA, regardless of this key.
ANTHROPIC_API_KEY=

# --- Claude Managed Agents: Sponsor Flow feasibility pipeline ---
# Non-secret resource IDs created by outputs/trialbridge_estimator/deploy.sh.
# The estimator needs all four IDs; ANTHROPIC_API_KEY above authenticates runtime sessions.
TB_PIPELINE_ENV_ID=
TB_INTAKE_AGENT_ID=
TB_PROPRIETARY_AGENT_ID=
TB_DATASUS_AGENT_ID=
# Optional durable queue location. Docker sets this to its persistent state volume.
# TB_CMA_JOBS_DB=/app/state/cma-jobs.sqlite3
# Shared bearer secret between Next.js and the estimator. Set the same value on both.
TB_ESTIMATOR_TOKEN=

# --- Python feasibility estimator (src/lib/estimator/client.ts) ---
# Base URL of the FastAPI estimator (DataSUS/OMOP over DuckDB). The sponsor
# journey's national feasibility numbers come from here. Default below.
TB_ESTIMATOR_URL=http://127.0.0.1:8421
# Human label for which DataSUS base the estimator is reading (shown in the UI).
# Point the estimator's TB_DATASUS_DIR at data/omop_sample (ships, thin) or
# data/omop_full (163GB, real national figure). See outputs/trialbridge_estimator.
TB_DATASUS_LABEL=DataSUS/OMOP (omop_sample)

# --- Tier 1 OMOP data source: DataSUS-style, DuckDB over GCS ---
# (src/lib/omop/datasource/duckdbGcs.ts). Optional — nothing in the app
# currently calls this adapter; it exists as plumbing for when real
# DataSUS access is wired up. Requires `npm install duckdb` yourself (see
# the file-level comment in duckdbGcs.ts for why it's not a hard dependency).
DATASUS_OMOP_GCS_PATH=gs://your-bucket/omop/*.parquet
DATASUS_OMOP_GCS_HMAC_KEY_ID=
DATASUS_OMOP_GCS_HMAC_SECRET=
# DuckDB schema/catalog the OMOP tables are attached under. Defaults to "main".
DATASUS_OMOP_DUCKDB_SCHEMA=main

# Parallel.ai Task API — deep web research pipe for KOL enrichment (optional).
# https://docs.parallel.ai/task-api  ·  key from https://platform.parallel.ai
PARALLEL_API_KEY=
# PARALLEL_BASE_URL=https://api.parallel.ai

# Materialized professional-directory inputs (server-only). The defaults below
# are used automatically outside Docker; Compose mounts them read-only under /app/data.
# TB_FACILITY_MASTER_DB=data/facility-master/facility-master.v1.sqlite
# TB_CTGOV_INVESTIGATOR_ROSTER=data/ctgov-investigators-br.json
