# Copy this to .env.local and fill in your own values. .env.local is
# gitignored — never commit real credentials.

# --- Claude parse service (src/lib/parse.ts) ---
# Optional. Without it, protocol parsing falls back to the cached, verified
# hero fixture (ADR Decision 3B) — the app works either way.
ANTHROPIC_API_KEY=

# --- Tier 1 OMOP data source: DataSUS-style, DuckDB over GCS ---
# (src/lib/omop/datasource/duckdbGcs.ts). Optional — nothing in the app
# currently calls this adapter; it exists as plumbing for when real
# DataSUS access is wired up. Requires `npm install duckdb` yourself (see
# the file-level comment in duckdbGcs.ts for why it's not a hard dependency).
DATASUS_OMOP_GCS_PATH=gs://your-bucket/omop/*.parquet
DATASUS_OMOP_GCS_HMAC_KEY_ID=
DATASUS_OMOP_GCS_HMAC_SECRET=
# DuckDB schema/catalog the OMOP tables are attached under. Defaults to "main".
DATASUS_OMOP_DUCKDB_SCHEMA=main
