          "archetype": "B / C",
          "variesPerStudy": "Sim"
        },
        {
          "idx": 8,
          "name": "Matriz de Variáveis",
          "content": "Grande grade: Disponível? / Fonte-Campo / Método / Completude / Observações — por variável, em ~9 categorias",
