# Copy to estimator/.env.local. Never commit the real values.
ANTHROPIC_API_KEY=
TB_PIPELINE_ENV_ID=
TB_INTAKE_AGENT_ID=
TB_PROPRIETARY_AGENT_ID=
TB_DATASUS_AGENT_ID=

# Must match TB_ESTIMATOR_TOKEN in ../.env.local when enabled.
TB_ESTIMATOR_TOKEN=

# Optional tuning. The current SQLite queue is designed for one worker process.
TB_CMA_WORKERS=1
TB_CMA_JOBS_DB=/app/state/cma-jobs.sqlite3
TB_CMA_EXECUTION_MODE=local

# Proprietary agent host tool. Inside Docker use the Compose service hostname;
# from a host-local estimator use http://localhost:9200 instead.
TB_PROPRIETARY_SEARCH_BACKEND=elasticsearch
TB_ELASTICSEARCH_URL=http://elasticsearch:9200
TB_ELASTICSEARCH_INDEX=clinical-demo-5ncts-v1

# Enable only for the six-case demo. Routing is strict: unsupported/missing NCT
# data fails instead of falling back to the full proprietary base.
# TB_DEMO_CASES_MANIFEST=/app/data/demo_cases/manifest.json
