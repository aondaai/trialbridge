// TrialBridge relational schema — the DOCUMENTED post-hackathon swap target.
//
// The hackathon build runs off a committed JSON snapshot (src/lib/store.ts) for
// reliability: no query engine, no file-URL edge cases, and the frozen demo
// snapshot is a plain committed file. This schema captures the same model so a
// continuation can `prisma db push` and switch the store implementation with the
// query code unchanged (ADR-001, Decision 2 — datasource is swappable).
//
// Note the privacy model is enforced at the schema level: a Response carries
// COUNTS and a bottleneck reference, never patient rows. Patients live per-site
// and never enter this shared store.

datasource db {
  provider = "sqlite"
  // DB lives in its own subdirectory so a Docker volume can be mounted at
  // prisma/data (persisting dev.db) without shadowing schema.prisma.
  url      = "file:./data/dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Site {
  id               String    @id
  name             String
  country          String
  city             String
  /// Brazilian macro-region (Norte/Nordeste/Centro-Oeste/Sudeste/Sul) — drives the regional breakdown.
  region           String    @default("")
  persona          String
  monthlyIncidence Int
  patients         Patient[]
}

/// A site's own patient record. The nested Patient shape (biomarkers/labs maps,
/// see src/lib/matcher/types.ts) is stored as a JSON string so the matcher type
/// is unchanged; rows live per-site and never cross the sponsor boundary.
model Patient {
  id     String @id
  siteId String
  /// JSON-serialized Patient (matcher types).
  data   String
  site   Site   @relation(fields: [siteId], references: [id])

  @@index([siteId])
}

model Consultation {
  id                   String   @id
  sponsorName          String
  title                String
  nct                  String?
  sourceNote           String?
  protocolText         String
  criteria             String // JSON-serialized Criterion[]
  /// Intended hero bottleneck handle, for the softening UI default.
  heroBottleneckHandle String?
  createdAt            DateTime @default(now())
  estimateStatus       String   @default("pending")
  estimateProtocol     String?
  estimateResult       String?
  estimateError        String?
  estimatedAt          DateTime?
  /// JSON-serialized progressive report lifecycle and per-pipeline results.
  reportRun             String?
}

// Relations to Consultation/Site are intentionally NOT enforced as FKs: the app
// starts empty and records are created live in any order (a site can respond, a
// sponsor can post) without a create-order dependency. siteName is denormalized
// so a response is self-describing. counts-not-rows: no patient list is
// representable here.
model Response {
  id               String   @id @default(cuid())
  consultationId   String
  siteId           String
  siteName         String
  definite         Int
  possible         Int
  excluded         Int
  total            Int
  bottleneckHandle String?
  bottleneckLabel  String?
  monthlyIncidence Int
  live             Boolean  @default(false)
  submittedAt      DateTime @default(now())

  @@unique([consultationId, siteId])
  @@index([consultationId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Feasibility Autofill module (docs/feasibility-autofill-reconciliation.md, F0).
// SQLite-flavored: enums and jsonb from the spec are stored as String (JSON where
// noted), matching the existing Patient.data convention. Multi-tenant isolation is
// by siteId, denormalized onto EVERY row (top-level and request-owned) so a per-site
// scope is an indexable WHERE clause, not a join-only invariant (code-review hardening).
// The privacy invariant holds: CohortDefinition stores a COUNT, never patient rows.
// ─────────────────────────────────────────────────────────────────────────────

/// Archetype A source of truth — the institution cadastre. One per site (versioned).
model InstitutionProfile {
  id                 String   @id @default(cuid())
  siteId             String
  legalName          String
  address            String   @default("")
  email              String   @default("")
  phone              String   @default("")
  website            String   @default("")
  /// anonymized | pseudonymized | identifiable
  anonymizationLevel String   @default("anonymized")
  lgpdBasis          String   @default("")
  ethicsCommittee    String   @default("")
  contractingDaysEst Int?
  acceptsEsignature  Boolean  @default(false)
  /// JSON: {data_dictionary:bool, flowchart:bool, ...}
  materials          String   @default("{}")
  version            Int      @default(1)
  updatedAt          DateTime @default(now())

  /// One profile row per (site, version); the binding reads the latest version.
  @@unique([siteId, version])
  @@index([siteId])
}

/// Archetype A — study-team roles present at the site (PM, epi, biostat, SME…).
model InstitutionTeam {
  id      String  @id @default(cuid())
  siteId  String
  role    String
  present Boolean @default(false)
  notes   String  @default("")

  @@unique([siteId, role])
  @@index([siteId])
}

/// A site database (a site may hold several: claims|emr|pharmacy|hospital|registry|lab|nlp_text).
model DataSource {
  id               String   @id @default(cuid())
  siteId           String
  name             String
  /// JSON string[] of kinds.
  kind             String   @default("[]")
  coverageNote     String   @default("")
  updateFrequency  String   @default("")
  patientCountEst  Int?
  updatedAt        DateTime @default(now())

  @@index([siteId])
}

/// Archetype B — the capability catalog (crown-jewel repository). One row per
/// (data source, canonical concept). Seeded from QuestionBank "Catálogo de Capacidade".
model CapabilityCatalog {
  id                   String   @id @default(cuid())
  siteId               String
  dataSourceId         String
  /// Canonical concept key (resolved via src/lib/omop/conceptResolver).
  conceptId            String
  /// yes | no | partial
  available            String   @default("partial")
  sourceField          String   @default("")
  identificationMethod String   @default("")
  completenessValue    Float?
  /// high | moderate | low
  completenessQual     String   @default("moderate")
  notes                String   @default("")
  version              Int      @default(1)
  lastValidatedAt      DateTime @default(now())

  @@unique([dataSourceId, conceptId])
  @@index([siteId])
}

/// A recognized sponsor form layout (fingerprint → structure). Cross-site by design.
model FormTemplate {
  id          String   @id @default(cuid())
  fingerprint String   @unique
  name        String
  /// JSON canonical section/field structure.
  structure   String   @default("{}")
  createdAt   DateTime @default(now())
}

/// An incoming sponsor feasibility request landing in a site's inbox (archetype router root).
model FeasibilityRequest {
  id              String   @id @default(cuid())
  siteId          String
  sponsorId       String?
  studyTitle      String
  protocolId      String?
  therapeuticArea String?
  /// ISO date-range string "start/end".
  indexWindow     String   @default("")
  /// JSON structured inclusion/exclusion criteria (matcher Criterion[] shape).
  criteria        String   @default("[]")
  originalFileKey String?
  templateId      String?
  status          String   @default("received")
  createdAt       DateTime @default(now())

  @@index([siteId])
}

/// One field of a parsed feasibility form, tagged with its archetype + concept.
model FormField {
  id        String  @id @default(cuid())
  requestId String
  /// Denormalized tenant key — makes per-site isolation an indexable WHERE, not a join-only invariant.
  siteId    String
  section   String
  label     String
  /// checkbox | yes_no_partial | text | number | matrix_cell
  cellType  String  @default("text")
  /// A | B | C | D
  archetype String
  conceptId String?
  /// JSON provenance/source pointer.
  sourceRef String?
  orderIdx  Int     @default(0)

  @@index([requestId])
  @@index([siteId])
}

/// A proposed/approved answer for a FormField — carries a serialized Metric as provenance.
model FieldAnswer {
  id         String   @id @default(cuid())
  fieldId    String
  /// Denormalized tenant key (see FormField.siteId).
  siteId     String
  /// JSON answer value.
  value      String   @default("null")
  /// JSON-serialized Metric (src/lib/metric.ts) — the mandatory provenance seal.
  provenance String
  /// high | medium | low
  confidence String   @default("low")
  /// JSON Kahn flags {conformance, completeness, plausibility}.
  dqFlags    String   @default("{}")
  /// proposed | approved | edited | rejected
  status     String   @default("proposed")
  reviewerId String?
  version    Int      @default(1)
  updatedAt  DateTime @default(now())

  @@index([fieldId])
  @@index([siteId])
}

/// Archetype C — a materialized cohort count for a request. COUNT only, never rows.
model CohortDefinition {
  id          String   @id @default(cuid())
  requestId   String
  /// Denormalized tenant key (see FormField.siteId).
  siteId      String
  /// JSON criteria set.
  criteria    String   @default("[]")
  /// JSON compiled SQL / OMOP cohort spec.
  sqlOrOmop   String   @default("{}")
  resultCount Int?
  suppressed  Boolean  @default(false)
  generatedAt DateTime @default(now())

  @@index([requestId])
  @@index([siteId])
}

/// Archetype D — RAG memory. Approved narrative answers, indexed for retrieval.
/// No PHI: stores answer TEXT, never patient data (LGPD invariant, spec §9).
model PriorFormAnswer {
  id         String   @id @default(cuid())
  siteId     String
  section    String
  label      String
  conceptId  String?
  answerText String
  /// JSON number[] embedding (nullable; embeddings live in the estimator, not pgvector).
  embedding  String?
  approvedAt DateTime @default(now())

  @@index([siteId])
}

/// Learned concept synonym (US-6) — a human concept mapping persisted so the classifier catches
/// the phrasing next time. Ontology-global (not site-scoped). Grows the PT-BR synonym layer.
model ConceptSynonym {
  id        String   @id @default(cuid())
  conceptId String
  /// Normalized (accent-folded, lowercased) term the classifier matches on.
  term      String
  lang      String   @default("pt-BR")
  /// seed | human | form
  source    String   @default("human")
  createdAt DateTime @default(now())

  @@unique([conceptId, term])
  @@index([conceptId])
}

/// Governance — every mutating action writes an audit row with an actor + diff.
model AuditLog {
  id       String   @id @default(cuid())
  siteId   String?
  entity   String
  entityId String
  action   String
  actor    String
  /// JSON before/after diff.
  diff     String   @default("{}")
  at       DateTime @default(now())

  @@index([entity, entityId])
}
