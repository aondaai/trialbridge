# dependencies
/node_modules
/.pnp
.pnp.js

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# misc
.DS_Store
*.pem
.vscode

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env
.env
.env*.local

# typescript
*.tsbuildinfo

# prisma / sqlite — dev.db is a real runtime database, generated by
# `npm run db:push` (empty). It is NOT committed; each environment builds its own.
# Lives under prisma/data/ so a Docker volume can persist it.
/prisma/data/
/prisma/dev.db
/prisma/dev.db-journal

# OHDSI Athena vocabulary bundle — large, licensed data, download it yourself
# from athena.ohdsi.org under your own account (docs/omop-vocabulary-mapping.md).
# NOTE: data/vocab-index.json (the small derived index) IS committed on purpose.
/data/vocab/

# DATASUS-OMOP export mirror (~165 GiB) pulled by scripts/download-omop-sus.sh
# from gs://omop-sus/exports/ihealth_omop_sus. Never commit this.
/data/omop-sus/

# Synthetic sample data written by `npm run generate-data` (a dev tool). The app
# no longer reads these at runtime — persistence is the Prisma DB (prisma/dev.db),
# which starts empty. Regenerate locally if you want sample rows to upload.
/data/site-*.json
/data/consultations.json
/data/responses.json
/data/index.json

# git worktrees for isolated agent work
/.claude/worktrees/
/data/kol-enrichment.json
/data/site-directory.json
/data/site-infra.json
/data/facility-master/
/data/ctgov-investigators-br.json
/data/ctgov-investigator-dedupe-audit.json

# large local data mirrors (never commit — see memory: DataSUS/proprietary bases)
/data/omop-sus/
/data/omop-sus-last10pct/
/data/omop_full/
/estimator/data/demo_cases/private/
# Committed demo data (behind Basic Auth; contact PII stripped from the directory)
# so a fresh deploy renders §5/§6/§7 with the real ABRACRO/ACESSE sites, not synthetic.
!/data/site-directory.json
!/data/site-infra.json
!/data/kol-enrichment.json

# PATIENT-LEVEL microdata — NEVER commit (real PHI: MRNs, DOB, clinical flags).
# Only the PHI-safe aggregates (estimator/data/*_base/records.json, finding_by_site.json,
# datasus_shell/aggregate.parquet) may be tracked. See the security review 2026-07-13.
/estimator/data/proprietary_ha/
/estimator/data/proprietary_prostate/
/estimator/data/omop_sample/
